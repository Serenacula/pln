---
import Base from '../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';

const specPath = path.resolve(process.cwd(), '..', 'specification.md');
const markdown = fs.readFileSync(specPath, 'utf-8');
const html = await marked.parse(markdown);
---

<Base title="Specification - PLN" description="The full Panel Layout Notation specification.">
  <article class="prose" set:html={html} />
</Base>
